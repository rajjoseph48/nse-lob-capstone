# Copy to .env and fill in. The real .env is gitignored — never commit it.
# Tokens (Dhan/Kite) expire daily at midnight IST; refresh each morning via kite_refresh_token.py.

KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

# EC2 collector host + SSH key (local convenience for sync/SSH)
EC2_HOST=
EC2_KEY_PATH=

# Optional: extra paths kite_refresh_token.py should also write the refreshed .env to
EXTRA_ENV_PATHS=
